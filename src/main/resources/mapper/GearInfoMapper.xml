<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.outdoor.rental.mapper.GearInfoMapper">

    <resultMap id="BaseResultMap" type="com.outdoor.rental.entity.GearInfo">
        <id     column="id"               property="id"/>
        <result column="gear_name"        property="gearName"/>
        <result column="brand"            property="brand"/>
        <result column="category"         property="category"/>
        <result column="daily_rent"       property="dailyRent"/>
        <result column="total_stock"      property="totalStock"/>
        <result column="available_stock"  property="availableStock"/>
        <result column="description"      property="description"/>
        <result column="status"           property="status"/>
        <result column="create_time"      property="createTime"/>
        <result column="update_time"      property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, gear_name, brand, category, daily_rent, total_stock,
        available_stock, description, status, create_time, update_time
    </sql>

    <!-- 多条件复合分页查询 -->
    <select id="selectGearPage" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM gear_info
        <where>
            <if test="query.gearName != null and query.gearName != ''">
                AND gear_name LIKE CONCAT('%', #{query.gearName}, '%')
            </if>
            <if test="query.category != null and query.category != ''">
                AND category = #{query.category}
            </if>
            <if test="query.brand != null and query.brand != ''">
                AND brand = #{query.brand}
            </if>
            <if test="query.status != null">
                AND status = #{query.status}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 原子扣减可用库存，防止超卖 -->
    <update id="deductAvailableStock">
        UPDATE gear_info
        SET available_stock = available_stock - 1
        WHERE id = #{gearId}
          AND available_stock > 0
          AND status = 1
    </update>

    <!-- 归还装备时恢复可用库存 -->
    <update id="restoreAvailableStock">
        UPDATE gear_info
        SET available_stock = available_stock + 1
        WHERE id = #{gearId}
          AND available_stock &lt; total_stock
    </update>

</mapper>
