# 本地配置模板（复制为 application-local.yml，该文件已在 .gitignore 中，切勿提交）
# Spring Boot 会自动加载 application-local.yml（若存在）
spring:
  datasource:
    username: root
    password: your-mysql-password

# AI 导购：请只在本地 application-local.yml 或环境变量中配置，不要写入仓库
# Windows: set AI_API_KEY=sk-xxx
# Linux/macOS: export AI_API_KEY=sk-xxx
ai:
  consultant:
    api-key: ${AI_API_KEY:}
    rag-max-items: 15
    max-history-messages: 8
