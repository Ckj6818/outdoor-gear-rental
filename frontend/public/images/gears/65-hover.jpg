<script type="text/template" id="instant_wrapper_template_products">
    {{#findAutocomplete}}
    <div id="algolia-autocomplete-container"></div>
    {{/findAutocomplete}}

    <div id="algolia_instant_selector"
         class="algolia-products h-full   with-facets">

        <div class="md:border-b md:border-rab-steel w-full algolia-block-filter">
            <div class="w-full flex justify-between"
                 id="algolia-left-container"
                 x-data="initCatalogFilter()"
                 x-bind="eventListeners"
            >
                <div class="flex flex-wrap items-center pt-6 md:py-5 gap-x-3 gap-y-2">
                    <template x-for="filter in highlightedFilters">
                        <template x-if="activeFacets.includes(filter.code)">
                            <button class="btn btn-outline focus:border-black bg-transparent rounded-full hidden md:inline-block hover:border-rab-sunset hover:bg-transparent"
                                    :class="countRefinements[filter.code] > 0 ? 'border-2 border-rab-sunset bg-transparent focus:border-rab-sunset' : ''"
                                    @click="triggerFilterFacet(filter.code)">
                                <span x-text="decodeURIComponent(filter.label)"></span>
                                <template x-if="countRefinements[filter.code]">
                                    <span class="leading-tight">
                                        <span x-text="'(' + countRefinements[filter.code] + ')'"></span>
                                        <button @click.stop="unselectFacetItems(filter.code)" class="ml-[10px] relative">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="inline-block" width="18" height="18" aria-hidden="true">
  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
</svg>
                                        </button>
                                    </span>
                                </template>
                            </button>
                        </template>
                    </template>

                    <button @click="openFilter()" class="btn rounded-full">All filters</button>
                    <div id="clear-refinements"></div>
                    <div id="current-refinements" class="hidden"></div>

                    <div class="backdrop z-40"
                         x-show="open"
                         style="display: none;"
                         x-transition:enter="ease-in-out duration-500"
                         x-transition:enter-start="opacity-0"
                         x-transition:enter-end="opacity-100"
                         x-transition:leave="ease-in-out duration-500"
                         x-transition:leave-start="opacity-100"
                         x-transition:leave-end="opacity-0"
                         role="button"
                         @click="closeFilter()"></div>
                    <div class="fixed z-40 top-0 right-0 w-[95%] max-w-[503px] h-full flex-col bg-container-lighter overflow-hidden px-8"
                         x-show="open"
                         style="display: none;"
                         x-transition:enter="transform transition ease-in-out duration-500 sm:duration-700"
                         x-transition:enter-start="translate-x-full"
                         x-transition:enter-end="translate-x-0"
                         x-transition:leave="transform transition ease-in-out duration-500 sm:duration-700"
                         x-transition:leave-start="translate-x-0"
                         x-transition:leave-end="translate-x-full"
                    >
                        <div class="pt-12 pb-7">
                            <h3 class="leading-none -tracking-[0.66px]">Filter by</h3>
                            <button
                                @click="closeFilter()"
                                class="absolute top-4 right-4"
                                aria-label="Close&#x20;filter"
                                type="button"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="block" width="28" height="28" aria-hidden="true">
  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
</svg>
                            </button>
                        </div>
                        <div id="instant-search-facets-container" class="overflow-y-auto overflow-x-hidden max-h-[calc(100%_-_233px)] border-t border-rab-steel"></div>
                        <div class="absolute bottom-0 left-0 w-full bg-white px-8 pt-6 pb-10">
                            <template x-if="hasRefinements">
                                <div class="grid grid-cols-2 gap-x-3">
                                    <button class="btn btn-outline hover:border-rab-sunset hover:bg-white h-[56px]" @click="clearAllRefinements()">Clear&#x20;&#x20;All</button>
                                    <button class="btn bg-rab-sunset text-black border border-transparent hover:bg-white hover:border-black h-[56px]"
                                            @click="closeFilter()"
                                            x-text="'Show&#x20;&#x25;1&#x20;results'.replace('%1',countHints)"
                                    ></button>
                                </div>
                            </template>
                            <template x-if="!hasRefinements">
                                <button class="btn w-full h-[56px]" @click="closeFilter()">Apply&#x20;filters</button>
                            </template>
                        </div>
                    </div>
                    <div class="ml-4 w-full sm:w-auto"><span class="text-cta leading-9 -tracking-[0.15px] font-medium text-black border-b-2 border-b-rab-sunset" x-text="'&#x25;1&#x20;products'.replace('%1',countHints)"></span></div>
                </div>

                <div id="algolia-sorts" class="pt-6"></div>
            </div>
        </div>

        <div class="w-full">
            <div class="w-full" id="algolia-right-container" x-data="{ flyoutLoginPlp: false }">
                <div class="hidden">
                    <div class="pb-3.5">
                        <div class="px-2.5">
                            {{#second_bar}}
                            <div id="instant-search-bar"></div>
                            {{/second_bar}}
                        </div>
                    </div>
                </div>
                <div>
                    <div>
                        <div itemscope itemtype="http://schema.org/ItemList" x-data="initStatsComponent()" x-bind="eventListeners">
                            <div id="algolia-banner"></div>
                            <div class="text-center mt-4">
                                <button @click="clickLoadPreviousButton()"
                                        :class="loadMoreWasClicked || currentPage == 0 ? 'hidden' : ''"
                                        class="btn w-full max-w-[420px] px-4 py-3 h-[56px] mx-auto">
                                    Load previous                                </button>
                            </div>
                            <div id="instant-empty-results-container"></div>

                            <div class="md:py-6 instant-search-results-container"></div>

                            <div class="text-center">
                                <div class="algolia-stats"></div>
                                <button @click="clickLoadMoreButton()"
                                        :class="helperPage < maxPage ? '' : 'hidden'"
                                        class="btn w-full max-w-[420px] px-4 py-3 h-[56px] mx-auto">
                                    Load more                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div>
                    <div id="instant-search-pagination-container"></div>
                </div>
            </div>
        </div>
    </div>
</script>

<div id="plp-content-cards" x-data="initPromoCardComponent()" x-bind="eventListeners" class="hidden">
    </div>

<script>
    'use strict';
    const initCatalogFilter = () => {
        return {
            init () {
                this.listOfFacets = window.search.helper.state.disjunctiveFacets;

                document.querySelector('#clear-refinements').addEventListener('click', () => {
                   this.clearAllRef();
                });
            },
            countHints: '',
            listOfFacets: [],
            activeFacets: [],
            highlightedFilters: [{"code":"pf_select_activities","label":"Activities"},{"code":"pf_select_benefits","label":"Performance"},{"code":"pf_select_claims","label":"Sustainability"}],
            hasRefinements: false,
            countRefinements: [],
            open: false,
            facetsAppeared: false,
            openFilter() {
                this.open = true;
                document.body.classList.add('overflow-hidden');
                document.documentElement.style['scrollbar-gutter'] = 'unset';
            },
            closeFilter() {
                document.body.classList.remove('overflow-hidden');
                document.documentElement.style['scrollbar-gutter'] = '';
                this.open = false
            },
            isFacetsApplied() {
                this.hasRefinements = false;
                for (const item of this.listOfFacets) {
                    const refinements = window.search.helper.getRefinements(item);
                    if (refinements.length > 0) {
                        this.hasRefinements = true;
                        break;
                    }
                }
            },
            async isFacetActive(attributeCode) {
                const delay = ms => new Promise(res => setTimeout(res, ms));
                await delay(200);

                const refinements = window.search.helper.getRefinements(attributeCode);
                if (refinements.length > 0) {
                    return true;
                } else {
                    return false;
                }
            },
            unselectFacetItems(attributeCode) {
                window.search.helper.clearRefinements(attributeCode).search()
                this.isFacetActive(attributeCode).then(result => {
                    if (!result) {
                        const button = document.querySelector(`.ais-Panel.${attributeCode} .clear-all`);
                        const selectedItemsDiv = document.querySelector(`.ais-Panel.${attributeCode} .selected-items`);
                        button.classList.add('hidden');
                        selectedItemsDiv.innerHTML = 'All';
                    }
                })
            },
            toggleFacetItem(el) {
                const container = el.closest('.ais-Panel');
                const attributeCode = container?.classList[1] || null;
                const selectedItemsDiv = container.querySelector('.selected-items');
                const button = container.querySelector('.clear-all');

                this.getFacetItems(attributeCode).then(result => {
                    if (result.length) {
                        selectedItemsDiv.innerHTML = '';
                        result.map((item) => {
                            let itemDiv = document.createElement('div');
                            itemDiv.innerHTML = item.value;
                            selectedItemsDiv.appendChild(itemDiv);
                        });
                        button.classList.remove('hidden');
                    } else {
                        selectedItemsDiv.innerHTML = 'All';
                        button.classList.add('hidden');
                    }
                }).catch(error => {
                    console.error(error);
                });
            },
            async getFacetItems(attributeCode) {
                const delay = ms => new Promise(res => setTimeout(res, ms));
                await delay(200);

                return window.search.helper.getRefinements(attributeCode);
            },
            processFacetAppeared() {
                //for dynamic widgets once rendered/initialized, callback from facet
                if (this.facetsAppeared) {
                    return;
                }

                this.facetsAppeared = true;
                this.addCustomElements();
            },
            addCustomElements() {
                const containers = document.querySelectorAll('#instant-search-facets-container .is-widget-container-dynamic-facets > div > div');
                const self = this;
                containers.forEach(function(container) {
                    let header = container.querySelector('.ais-Panel-header');

                    if (!header) {
                        //empty dynamic widget
                        return;
                    }

                    const aisPanelContainer = container?.querySelector('.ais-Panel');
                    let facetAttr = aisPanelContainer?.classList[1] || null;

                    // Create a div for selected items
                    var selectedItemsDiv = document.createElement('div');
                    selectedItemsDiv.className = 'selected-items';
                    header.appendChild(selectedItemsDiv);

                    self.getFacetItems(facetAttr).then(result => {
                        if (result.length) {
                            selectedItemsDiv.innerHTML = '';
                            result.map((item) => {
                                let itemDiv = document.createElement('div');
                                itemDiv.innerHTML = item.value;
                                selectedItemsDiv.appendChild(itemDiv);
                            });
                        } else {
                            selectedItemsDiv.innerHTML = 'All';
                        }
                    }).catch(error => {
                        console.error(error);
                    });

                    // Create a button element
                    var button = document.createElement('button');
                    button.innerHTML = 'Unselect all';
                    button.className = 'clear-all btn-text-cta';
                    header.querySelector('span').appendChild(button);
                    self.isFacetActive(facetAttr).then(result => {
                        if (!result) {
                            button.classList.add('hidden');
                        }
                    }).catch(error => {
                        console.error(error);
                    });
                    button.addEventListener('click', function(e) {
                        e.stopPropagation();
                        self.unselectFacetItems(facetAttr)
                        selectedItemsDiv.innerHTML = 'All';
                    });

                    header.addEventListener('click', function() {
                        this.closest('.ais-Panel').classList.toggle('open');
                    });
                })
            },
            clearAllRef() {
                const selectedItemsDivs = document.querySelectorAll('#instant-search-facets-container .selected-items');
                const buttons = document.querySelectorAll('#instant-search-facets-container .clear-all');
                buttons.forEach(function(item) {
                    item.classList.add('hidden');
                });
                selectedItemsDivs.forEach(function(item) {
                    item.innerHTML = 'All';
                });

                this.hasRefinements = false;
            },
            clearAllRefinements() {
                this.clearAllRef();
                document.querySelector('.ais-ClearRefinements-button').click();
                this.closeFilter();
            },
            getActiveItemOfFacet(attributeCode) {
                return window.search.helper.getRefinements(attributeCode).length;
            },
            triggerFilterFacet(attributeCode) {
                this.openFilter();
                document.querySelector(`.ais-Panel.${attributeCode}`).classList.add('open');
            },
            sortDynamicWidgets() {
                let classOrder = this.highlightedFilters.map(item => item.code);
                classOrder = classOrder.reverse();

                const widgets = Array.from(document.querySelectorAll(".ais-DynamicWidgets-widget"));

                widgets.sort((a, b) => {
                    const aClass = a.querySelector(".ais-Panel")?.classList[1] || "";
                    const bClass = b.querySelector(".ais-Panel")?.classList[1] || "";
                    return classOrder.indexOf(bClass) - classOrder.indexOf(aClass);
                });

                const container = document.querySelector(".ais-DynamicWidgets");
                if (container) {
                    widgets.forEach(widget => container.appendChild(widget));
                } else {
                    console.error('Container not found for sortDynamicWidgets');
                }
            },
            eventListeners: {
                ['@search-on-render-custom-products-event.window'](event) {
                    let self = this;

                    this.activeFacets = event.detail.disjunctiveFacets.map(item => item.name);
                    this.highlightedFilters.forEach(item => {
                        self.countRefinements[item.code] = this.getActiveItemOfFacet(item.code);
                    });

                    this.countHints = event.detail.nbHits;
                    this.isFacetsApplied();
                },
                ['@after-instantsearch-start-custom-event.window'](event) {
                    this.sortDynamicWidgets();
                }
            }
        }
    }

    const initStatsComponent = () => {
        return {
            currentItemsCount: 0,
            allItems: 0,
            currentPage: 0,//debug
            queryPage: 0,//debug
            maxPage: 1,//-1
            helperPage: 0,
            hitsPerPage: 68,
            loadMoreWasClicked: false,
            initStats () {
                //const urlParams = new URLSearchParams(window.location.search);
                //this.currentUrlPage = urlParams.has('page') ? parseInt(urlParams.get('page'), 10) : 0;
                this.maxPage--;
            },
            clickLoadPreviousButton() {
                document.querySelector('.algolia-products .ais-InfiniteHits-loadPrevious').click();
            },
            clickLoadMoreButton() {
                this.loadMoreWasClicked = true;
                document.querySelector('.algolia-products .ais-InfiniteHits-loadMore').click();
            },
            eventListeners: {
                ['@search-on-render-custom-products-event.window.once'](event) {
                    window.dispatchEvent(new CustomEvent('search-page-product-count', {detail: event.detail}));
                },
                ['@search-on-render-custom-products-event.window'](event) {
                    this.helperPage = window.search.helper.state.page;
                    window.dispatchEvent(new CustomEvent('search-page-product-count', {detail: event.detail}));
                }
            }
        }
    }

    const initPromoCardComponent = () => {
        return {
            eventListeners: {
                ['@after-instantsearch-start-custom-event.window'](event) {
                    const products = document.querySelectorAll('.instant-search-results-container .ais-InfiniteHits-item')
                    const insertedCards = document.querySelectorAll('.instant-search-results-container .promo-card')
                    const cards = document.querySelectorAll('#plp-content-cards .promo-card')

                    insertedCards.forEach(function(card) {
                        card.remove();
                    });

                    cards.forEach(function(card) {
                        let index = card.dataset.index;
                        if (products.length >= index && index > 0) {
                            products[index-1].insertAdjacentElement('afterend', card.cloneNode(true));
                        }
                    });
                }
            }
        }
    }

    const initStoryblokPagesComponent = () => {
        return {
            nbPages: 0,
            page: 0,
            initStats () {},
            clickLoadMoreContentButton() {
                document.querySelector('.algolia-content .ais-InfiniteHits-loadMore').click();
            },
            contentEvent(event) {
                this.nbPages = event.detail.nbPages;
                this.page = event.detail.page;
            },
            get showLoadMore() {
                return (this.page + 1) < this.nbPages;
            }
        }
    }
</script>
<script type="text/template" id="instant-stats-template">
    <div class="text-regular-body -tracking-[0.15px] mb-[15px] text-center"
         x-init="hitsPerPage = {{hitsPerPage}};currentItemsCount = {{last}}; queryPage = {{page}}; allItems = {{nbHits}}; currentPage = {{page}};  maxPage = {{nbPages}}; initStats();">
        {{#hasOneResult}}
            <div>1 Item</div>
        {{/hasOneResult}}
        {{#hasManyResults}}
            <div>{{last}} / {{nbHits}} Items</div>
        {{/hasManyResults}}
        {{#hasNoResults}}
            <div>Your search returned no results.</div>
        {{/hasNoResults}}
    </div>
</script>
<script type="text/template" id="refinements-lists-item-template">
    <label class="{{cssClasses.label}} {{#isRefined}}checked{{/isRefined}}" x-init="processFacetAppeared" @click='toggleFacetItem($el)'>
        <input class="{{cssClasses.checkbox}}" {{#isRefined}}checked{{/isRefined}} type="checkbox" value="{{value}}" />
        <span>{{value}} ({{count}})</span>
    </label>
</script>
<script type="text/template" id="current-refinements-template">
    <div class="cross-wrapper">
        <span class="clear-cross clear-refinement"></span>
    </div>
    <div class="current-refinement-wrapper">
        {{#label}}
        <span class="current-refinement-label">{{label}}{{^operator}}:{{/operator}}</span>
        {{/label}}
        {{#operator}}
        {{{displayOperator}}}
        {{/operator}}
        {{#exclude}}-{{/exclude}}
        <span class="current-refinement-name">{{name}}</span>
    </div>
</script><script type="application/json" id="default-section-data">
    {"messages":[],"customer":[],"compare-products":[],"last-ordered-items":[],"cart":[],"directory-data":{"GB":{"name":"United Kingdom"},"GG":{"name":"Guernsey"},"JE":{"name":"Jersey"},"data_id":1781508401},"captcha":[],"wishlist":{"items":[]},"instant-purchase":[],"loggedAsCustomer":[],"multiplewishlist":[],"persistent":[],"review":[],"amga4_event_pool":[],"hbcc-checkout-data":[],"hyva_checkout":[],"amga4_hyva_event_pool":[],"yotposms-customer-behaviour":[],"recently_viewed_product":[],"recently_compared_product":[],"product_data_storage":[],"paypal-billing-agreement":[]}</script>

<div x-cloak x-data="tooltip">
    <div class="backdrop z-50"
         x-show="open"
         x-transition:enter="ease-in-out duration-500"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in-out duration-500"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         role="button"
         @click="open = false;document.body.classList.remove('noscroll');"></div>
    <div class="fixed inset-y-0 right-0 z-50 w-full max-w-lg bg-white"
         x-show="open"
         x-transition:enter="transform transition ease-in-out duration-500 sm:duration-700"
         x-transition:enter-start="translate-x-full"
         x-transition:enter-end="translate-x-0"
         x-transition:leave="transform transition ease-in-out duration-500 sm:duration-700"
         x-transition:leave-start="translate-x-0"
         x-transition:leave-end="translate-x-full">
        <div class="relative px-8 lg:pr-4 py-12 max-h-screen overflow-y-auto lg:mr-4">
            <button
                @click="open = false;document.body.classList.remove('noscroll');"
                class="absolute top-4 right-3"
                type="button"
            >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24" aria-hidden="true">
  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
</svg>
            </button>

            <div class="mb-8 text-regular-body autotag_content"></div>
        </div>
    </div>
</div>

<script type="text/javascript">
    document.addEventListener('alpine:init', () => {
        Alpine.data('tooltip', () => ({
            open: false,

            init() {
                const tooltips = document.querySelectorAll('.tooltip');
                tooltips.forEach(tooltip => {
                    tooltip.addEventListener('click', (e) => this.openModal(e));
                });

            },

            async openModal(e){
                const slug = e.currentTarget.dataset.slug,
                    autotag_content = document.querySelector('.autotag_content');

                if (!autotag_content.querySelector('#' + slug)) {
                    const tag = document.createElement('div');
                    const response = await fetch('https://rab.equipment/uk/autotag/index/index/?' + new URLSearchParams({
                        slug: slug
                    }));
                    tag.id = slug;
                    tag.innerHTML = response.ok ? await response.text() : 'Awaiting content.';
                    console.log(tag)
                    autotag_content.appendChild(tag);
                }

                autotag_content.querySelectorAll('div').forEach(tag => {
                    if (!tag.classList.contains('cms_buttons') && !tag.classList.contains('tooltip-logo') && !tag.classList.contains('tooltip-extras')) {
                        tag.classList.add('hidden');
                    }
                })
                autotag_content.querySelector('#' + slug).classList.remove('hidden');

                this.open = true;
            },
        }))
    })
</script>
</div></body>
</html>
