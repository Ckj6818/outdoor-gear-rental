</div></div></div></div></div></main><footer class="footer w-full bg-rab-black text-white"><div class="footer content"><div class="footer-subscribe-container bg-white">
<div
    x-data="{ shown: false }"
    x-intersect="shown = true"
    x-init="$nextTick(() => { $el.getBoundingClientRect().top < 0 ? shown = true : '' })"
    :class="{ 'fade-in': shown }"
    class="py-10 container transition ease-in-out">
    <div class="p-0 mx-auto grid md:grid-cols-2 rounded-xl overflow-hidden bg-rab-pebble">
        <div class="newsletter-image">
            <img loading="lazy" width="880" height="660" src="https://a.storyblok.com/f/295180/1500x1000/30b0b1606a/aw25-signup-winter-ski.jpg" alt="" />
        </div>
        <div class="flex items-center justify-center px-4 py-6 w-full">
            <form
                class="form subscribe max-w-[370px] w-full mx-auto"
                action="https://rab.equipment/uk/newsletter/subscriber/new/"
                method="post"
                x-data="initNewsletterForm()"
                @submit.prevent="submitForm()"
                id="newsletter-validate-detail"
                aria-label="Subscribe&#x20;to&#x20;newsletter"
            >
                <h2 class="h2 -tracking-[1.5px] leading-none mb-2 md:mb-4 text-black" id="footer-newsletter-heading">
                    Newsletter signup                </h2>
                <div class="text-regular-body mb-5 md:mb-6 text-black">
                    <p><span style="color:#000000">Stay up-to-date with the latest product news and receive updates from our global community of athletes and partners.</span></p>                </div>
                <div class="flex">
                    <label for="newsletter-subscribe" class="sr-only">
                        Email address                    </label>
                    <input
                        x-model="newsletterSubscribe"
                        :class="disabled ? 'pointer-events-none' : ''"
                        name="email"
                        type="email"
                        required
                        id="newsletter-subscribe"
                        class="form-input inline-flex w-full py-0 px-5 text-rab-graphene placeholder:text-rab-steele border-rab-steel focus:border-rab-graphene focus:text-rab-black focus:placeholder:text-rab-black rounded-r-none"
                        placeholder="Your&#x20;email"
                        aria-describedby="footer-newsletter-heading"
                    >
                    <input type="hidden" name="form_key" :value="hyva.getFormKey()" value="" />
                                        <button class="inline-flex shrink-0 btn btn-sunset rounded-l-none"
                            :class="disabled ? 'bg-rab-background text-rab-cloud pointer-events-none' : ''"
                    >
                        Join now                    </button>
                </div>
                <div>
                    <template x-if="displayErrorMessage">
                        <p class="flex items-center text-red">
                    <span class="inline-block w-8 h-8 mr-3 pt-1">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24" role="img">
  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
<title>exclamation-circle</title></svg>
                    </span>
                            <template x-for="errorMessage in errorMessages">
                                <span x-html="errorMessage"></span>
                            </template>
                        </p>
                    </template>
                </div>
                <div class="w-full">
                                    </div>
            </form>
        </div>
    </div>
</div>

<script>
    function initNewsletterForm() {
        return {
            isLoading: false,
            newsletterSubscribe: '',
            disabled: false,
            errors: 0,
            hasCaptchaToken: 0,
            displayErrorMessage: false,
            errorMessages: [],
            setErrorMessages(messages) {
                this.errorMessages = [messages]
                this.displayErrorMessage = this.errorMessages.length
            },
            submitForm() {
                this.isLoading = true;
                // Do not rename $form, the variable is expected to be declared in the recaptcha output
                const $form = document.querySelector('#newsletter-validate-detail');
                                if (this.errors === 0) {
                    const url = "https://rab.equipment/uk/unified_newsletter/subscriber_ajax/new/";
                    const body = new URLSearchParams({form_key: hyva.getFormKey(), email: this.newsletterSubscribe});
                    const contentType = 'application/x-www-form-urlencoded;';
                    fetch(url, {method: 'post', body, headers: {'Content-Type': contentType}})
                        .then(response => {
                            this.isLoading = false;
                            if (response.errors) {
                                this.setErrorMessages(response.message);
                            }
                            if (response.redirected) {
                                window.location.href = response.redirectUrl;
                            } else if (response.ok) {
                                return response.json();
                            } else {
                                this.setErrorMessages("Post request failed");
                            }
                        })
                        .then(response => {
                            this.isLoading = false;
                            if (!response) {
                                return;
                            }
                            if (response.errors) {
                                this.setErrorMessages(response.message);
                            } else {
                                this.newsletterSubscribe = response.message
                                this.disabled = true;
                                this.errorMessages = [];
                                this.displayErrorMessage = false;
                            }
                        })
                        .catch(error => {
                            this.isLoading = false;
                            this.setErrorMessages("Some unknown error occurred. Please try again.");
                        });
                }
            }
        }
    }
</script>
