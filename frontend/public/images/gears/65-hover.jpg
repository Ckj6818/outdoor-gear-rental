<script>
    function initHeader () {
        return {
            scrolAtTop: true,
            headerWhite: document.getElementById('header').classList.contains('header-white'),
            searchOpen: false,
            cart: {},
            isCartOpen: false,
            hovered: false,
            isMobile: false,
            init() {
              let self = this;

              this.checkIsMobileResolution();
              this.calculateAlgoliaInputBoxStyle();

                document.body.addEventListener('click', function(event) {
                    if (event.target.classList.contains('aa-Form')) {
                        if (self.isMobile) {
                            algoliaAutocompleteObject.setQuery('');
                            document.querySelector('.aa-Input').focus();
                        } else {
                            self.searchOpen = false;
                            //document.querySelector('.page-header').classList.add('transparent-menu');
                            document.querySelector('.page-header').dispatchEvent(new Event("mouseout"));
                            event.stopPropagation()
                            event.stopImmediatePropagation()
                            document.querySelector('.aa-Input').blur();
                        }

                    }
                });
            },
            checkIsMobileResolution() {
                this.isMobile = window.matchMedia('(max-width: 767px)').matches;
            },
            calculateAlgoliaInputBoxStyle() {
                const leftEl = this.$refs['nav-desktop-menu'].getBoundingClientRect();
                const rightEl = this.$refs.searchIcon.getBoundingClientRect();

                const rightCalc = window.innerWidth - rightEl.right;
                const leftCalc = leftEl.left;

                this.$refs.algoliaSearchInput.style.left = `${leftCalc}px`;
                this.$refs.algoliaSearchInput.style.right = `${rightCalc}px`;
                this.$refs.algoliaSearchInput.style.width = `${window.innerWidth - leftCalc - rightCalc}px`;
            },
            getData(data) {
                if (data.cart) { this.cart = data.cart }
            },
            isCartEmpty() {
                return !this.cart.summary_count
            },
            get isTopScroll() {
              return !(this.searchOpen || !this.scrolAtTop) ;
            },
            toggleCart(event) {
                if (event.detail && event.detail.isOpen !== undefined) {
                    this.isCartOpen = event.detail.isOpen
                    if (!this.isCartOpen && this.$refs && this.$refs.cartButton) {
                        this.$refs.cartButton.focus()
                    }
                } else {
                                        this.isCartOpen = true
                }
            },
            handleSearchClick() {
                this.calculateAlgoliaInputBoxStyle();
                this.searchOpen = true;
                document.querySelector('.page-header').classList.remove('transparent-menu');

                if (this.searchOpen) {
                        setTimeout(function () {
                            const inputElement = document.querySelector('.aa-Input');
                            if (inputElement) {
                                inputElement.focus();
                            }
                        }, 200);

                        // Check when element is in the dom with observer
                        function onElementInserted(callback, selector) {
                        // Create a new MutationObserver instance
                        const observer = new MutationObserver((mutationsList, observer) => {
                            for (const mutation of mutationsList) {
                            // Check if the added nodes contain the target element
                            if (mutation.addedNodes.length > 0) {
                                const element = document.querySelector(selector);
                                if (element) {
                                callback(element);
                                // disconnect observer after detecting the element
                                //observer.disconnect();
                                }
                            }
                            }
                        });

                        // Start observing the document for changes
                        observer.observe(document.body, {
                            childList: true, // Listen for added/removed elements in the body
                            subtree: true // Watch for elements added anywhere in the DOM
                        });
                        }

                        // Usage
                        onElementInserted((element) => {
                            setTimeout(function () {
                            element.classList.remove('hidden');
                            }, 500);
                        }, '.algolia-no-results');

                        window.algoliaAutocompleteObject?.setIsOpen(true);//js console
                } else {
                    if (document.querySelector('.aa-Input') && document.querySelector('.aa-Input').value.length > 0) {
                        window.location = window.algoliaConfig.baseUrl
                            + '/catalogsearch/result/?q='
                            + encodeURIComponent(document.querySelector('.aa-Input').value);
                    }
                }
            },
            handleSearchOutside(e) {
                if (!e.target.classList.contains('aa-Input')) {
                    //close search
                }
            },
            processClickOutside(e) {
                if (!e.target.closest('.autocomplete_panel')) {
                    //console.log('Click occurred outside of .autocomplete_panel');
                    this.searchOpen = false;
                    //document.querySelector('.page-header').classList.add('transparent-menu');
                    document.querySelector('.page-header').dispatchEvent(new Event("mouseout"));
                }
            }
        }
    }
    function initCompareHeader() {
        return {
            compareProducts: null,
            itemCount: 0,
            receiveCompareData(data) {
                if (data['compare-products']) {
                    this.compareProducts = data['compare-products'];
                    this.itemCount = this.compareProducts.count;
                }
            }
        }
    }
</script>

<div id="header"
     x-data="initHeader()"
     class="relative z-20 w-full py-2 lg:py-0 transition ease-linear duration-200"
     :class="{
        'bg-transparent top-position': isTopScroll === true && !hovered,
        'bg-white': isTopScroll === false || hovered,
        'header-white': isTopScroll && headerWhite && !hovered
     }"

     @mouseover="hovered = isMobile ? false : true"
     @mouseout="hovered = false"
     @scroll.window="scrolAtTop = (window.pageYOffset > 5) ? false : true"
     @resize.window.debounce="calculateAlgoliaInputBoxStyle();checkIsMobileResolution()"
     @private-content-loaded.window="getData(event.detail.data)"
>
