window.getAmGa4Cookie = function () {
    let cookies = {};
    document.cookie.split(';').forEach(function (el) {
        let [key, value] = el.split('=');
        cookies[key.trim()] = value;
    });

    return cookies['amga4_customer']
        ? decodeURIComponent(cookies['amga4_customer'])
        : '{}';
};

