<script>
    function initCarousel_6a2f9c2fb9124() {
        return {
            style: "default",
            activeSlide: 0,
            visibleSlidesDesktop: 1,
            visibleSlidesMobile: 1,
            slideCount: 3,
            gapSizeDesktop: 40,
            gapSizeMobile: 16,
            isMobile: false,
            startX: 0,
            endX: 0,
            dragOffset: 0,
            autoplay: 0,
            autoplaySpeed: 4000,
            checkIsMobileResolution() {
                this.isMobile = window.matchMedia('(max-width: 767px)').matches;
            },
            init() {
                this.checkIsMobileResolution();

                if (this.autoplay) {
                    setInterval(() => this.nextSlide(), this.autoplaySpeed)
                }
            },
            get isZoomStyle() {
                return this.style === 'zoom';
            },
            get gapSize() {
                return this.isMobile ? this.gapSizeMobile : this.gapSizeDesktop;
            },
            get gapPercentage() {
                return Math.ceil((this.gapSize / this.$root.clientWidth) * 100);
            },
            get visibleSlides() {
                return Number(this.isMobile ? this.visibleSlidesMobile : this.visibleSlidesDesktop);
            },
            prevSlide() {
                if (this.activeSlide > 0) {
                    this.activeSlide--;
                }
            },
            nextSlide() {
                if (this.activeSlide < this.slideCount - this.visibleSlides) {
                    this.activeSlide++;
                } else {
                    this.activeSlide = 0;
                }
            },
            startDrag(event) {
                this.startX = event.touches[0].clientX;
                this.dragOffset = 0;
            },
            onDrag(event) {
                this.endX = event.touches[0].clientX;
                this.dragOffset = this.endX - this.startX;
            },
            endDrag() {
                if (this.startX > this.endX + 50) {
                    this.nextSlide();
                } else if (this.startX < this.endX - 50) {
                    this.prevSlide();
                }
                this.dragOffset = 0;
            },
            getSlideClasses() {
                return 'visible-slide';
            }
        }
    }
</script>
