:"NO RESULTS FOUND Sorry, we have found no matching products.","noProducts2":"Please refine your selection or try a different search.","noSearchResults":"Sorry, we have been unable to find any matching products.","noSearchResults2":"Please try a different search, or visit some of our popular categories below.","noSearchResults3":"Suggested categories:","category1":"Waterproof Jackets","category2":"Insulated Jackets","category3":"Men's Fleece","category4":"Women's Fleece","category5":"All Men's Legwear","category6":"All Women's Legwear","category7":"All Sleeping Bags","category8":"All Packs"},"storyblokIndexName":"rab_live_storyblok_pages","storeCode":"uk"}, {
                resultURL:'https\u003A\u002F\u002Frab.equipment\u002Fuk\u002Fcatalogsearch\u002Fresult\u002F',
                placeholder: 'Search'
            }
        )
        const instantsearchScripts = ["https:\/\/rab.equipment\/static\/version1779887681\/frontend\/Rab\/hyva\/en_US\/Hyva_AlgoliaSearch\/js\/internals\/algoliaBundle.min.js","https:\/\/rab.equipment\/static\/version1779887681\/frontend\/Rab\/hyva\/en_US\/Hyva_AlgoliaSearch\/js\/internals\/common.js","https:\/\/rab.equipment\/static\/version1779887681\/frontend\/Rab\/hyva\/en_US\/Hyva_AlgoliaSearch\/js\/internals\/instantsearch.js"]
        const autocompleteScripts = ["https:\/\/rab.equipment\/static\/version1779887681\/frontend\/Rab\/hyva\/en_US\/Hyva_AlgoliaSearch\/js\/internals\/autocomplete-js.js","https:\/\/rab.equipment\/static\/version1779887681\/frontend\/Rab\/hyva\/en_US\/Hyva_AlgoliaSearch\/js\/internals\/algoliasearch.js","https:\/\/rab.equipment\/static\/version1779887681\/frontend\/Rab\/hyva\/en_US\/Hyva_AlgoliaSearch\/js\/internals\/algoliasearch-query-suggestion-plugin.js"]
        function loadScript (url) {
            let script = document.createElement('script')
            script.setAttribute('type', 'text/javascript')
            script.setAttribute('src', url)
            document.head.append(script)

            return new Promise((resolve) => script.addEventListener('load', resolve))
        }

        function loadScripts(scripts) {
            return Promise.all(scripts.map(loadScript))
        }

        let autocompleteInitialized = false

        async function initAlgoliaAutoComplete() {
            if (autocompleteInitialized) {
                return
            }

            autocompleteInitialized = true

            await loadScripts(autocompleteScripts)
            await loadScript('https\u003A\u002F\u002Frab.equipment\u002Fstatic\u002Fversion1779887681\u002Ffrontend\u002FRab\u002Fhyva\u002Fen_US\u002FHyva_AlgoliaSearch\u002Fjs\u002Finternals\u002FautocompleteConfig.js')
        }
        function initInstantSearch() {
            loadScripts(instantsearchScripts).then(() => {
                algoliaCommon()
                initAlgoliaInstantSearch('products')
                if (!algoliaConfig.isCategoryPage && algoliaConfig.isSearchPage) {
                    initAlgoliaInstantSearch('storyblok_pages')
                }
            })
        }

        if (algoliaConfig.autocomplete.enabled) {
            window.addEventListener('load', function() {
                initAlgoliaAutoComplete()
                // autocomplete library autoFocus configuration param doesn't work
                //document.querySelector('#algolia-autocomplete-container input').focus()
            });
        }

        if (algoliaConfig.instant.enabled && algoliaConfig.isSearchPage) {
            initInstantSearch()
        }

        // JC - To refactor later
        // prev implementation - window.quickSearchCms = '(echo php here) base64_encode($block->getChildHtml('storyblok.autocomplete.cms')) (close php here)';

        function fetchHtmlElementFromOtherPage() {
            // Get the current URL
            const currentUrl = window.location.href;
            //console.log('Current URL:', currentUrl);

            // Regular expression to match the base URL up to the desired segment (e.g., '/eu_fr/', '/uk/', etc.)
            const regex = /(https?:\/\/[^\/]+\/[^\/]+\/)/;
            const match = currentUrl.match(regex);
            let fullUrl = '';

            if (match) {
                const baseUrl = match[1];
                //console.log('Base URL:', baseUrl); // Output the base URL

                // Example URL for fetching HTML element
                fullUrl = baseUrl + 'quicksearch-no-results';
                //console.log('Full URL:', fullUrl); // Output the full URL

            } else {
                // Check if fullUrl ends in forward slash
                if (currentUrl.endsWith('/')) {
                    fullUrl = currentUrl + 'quicksearch-no-results';
                } else {
                    fullUrl = currentUrl + '/quicksearch-no-results';
                }
                //console.log('Full URL:', fullUrl); // Output the full URL
            }

            //console.log(fullUrl);
            fetch(fullUrl)
                    .then(response => response.text())
                    .then(data => {
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(data, 'text/html');
                        const element = doc.querySelector('.column.main');
                        if (element) {
                            //console.log('Found element in the fetched page:', element);
                            window.quickSearchCms = element.innerHTML;
                        } else {
                            console.error('Element not found in the fetched page');
                        }
                    })
                    .catch(error => console.error('Error fetching the HTML element:', error));

        }

        window.addEventListener('load', function() {
            fetchHtmlElementFromOtherPage();
        });
        
    </script>
