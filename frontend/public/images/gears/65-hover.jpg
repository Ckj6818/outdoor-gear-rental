    <script>
        function initMenuSection(config) {
            return {
                open: false,
                mouseLeaveTimeout: 0,
                mouseLeaveTimer: null,
                uId: config.uId,
                init(){
                },
                processHover(isOpened) {
                    let self = this;

                    if (isOpened) {
                        this.open = true;
                        clearTimeout(this.mouseLeaveTimer);
                        window.dispatchEvent(new CustomEvent('close-megamenu-sections', {detail: {except: this.uId}}));
                        document.getElementById('menu-backdrop').classList.remove('hidden');
                        
                    } else {
                        this.mouseLeaveTimer = setTimeout(() => {
                            self.open = false;
                        }, this.mouseLeaveTimeout);
                        document.getElementById('menu-backdrop').classList.add('hidden');
                    }
                },
                canHover(func) {
                    const isHoverableDevice = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
                    if (!isHoverableDevice) return;
                    func();
                },
                processSectionCloseEvent(event) {
                    if (this.uId !== event.detail.except) {
                        this.open = false;
                        clearTimeout(this.mouseLeaveTimeout);
                    }
                }
            }
        }
    </script>
