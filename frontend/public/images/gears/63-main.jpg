<script>
  document.addEventListener('click', function (event) {
  const button = document.getElementById('openCustomDropdown');
  const dropdown = document.getElementById('dropdownMenu');

  if (!button || !dropdown) return;

  const isButtonClick = button.contains(event.target);
  const isDropdownClick = dropdown.contains(event.target);

  if (isButtonClick) {
      const divHeight = document.querySelector('.announcement-top-bar').clientHeight;
      button.classList.toggle('active');
      dropdown.style.top = `${divHeight}px`;
      dropdown.classList.toggle('hidden');
  } else if (!isDropdownClick && !dropdown.classList.contains('hidden')) {
      dropdown.classList.add('hidden');
      button.classList.remove('active');
  }
  });
  const klaviyoSignup = document.querySelector('.klaviyo_signup');
  if (klaviyoSignup) {
    klaviyoSignup.addEventListener('click', function (){
    window._klOnsite = window._klOnsite || [];
      window._klOnsite.push(['openForm', 'TXuCeG']);
    });
  }
</script>

