     <script>
      document.addEventListener("DOMContentLoaded", function () {
        const source = document.querySelector(".cart-count-bubble .visually-hidden");
        const target = document.querySelector(".drawer__count[data-hex-count]");

        if (!source || !target) return;

        function updateCount() {
          target.textContent = source.textContent.trim();
        }

        // run once
        updateCount();

        // listen for runtime changes
        const observer = new MutationObserver(updateCount);
        observer.observe(source, {
          childList: true,
          characterData: true,
          subtree: true
        });
      });
    </script>


    


