    const intervalId = setInterval(() => {
    const inputs = document.querySelectorAll('.rbr-checkbox-input');
    let missing = 0;
    inputs.forEach(input => {
      if (!input.getAttribute('aria-label')) {
        input.setAttribute('aria-label', 'Select option');
        missing++;
      }
    });
    if (missing === 0) {
        clearInterval(intervalId);
      }
    }, 1000);
  </script>
