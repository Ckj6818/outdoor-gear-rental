  document.addEventListener('DOMContentLoaded', function() {
    const closeButton = document.querySelector('.menu-drawer__header-close');
    const headerDrawer = document.querySelector('header-drawer');
    const menuDrawerSummary = document.querySelector('#Details-menu-drawer-container summary');
    
    if (closeButton && headerDrawer) {
      closeButton.addEventListener('click', function(event) {
        event.preventDefault();
        if (headerDrawer.mainDetailsToggle && headerDrawer.mainDetailsToggle.hasAttribute('open')) {
          headerDrawer.closeMenuDrawer(event, menuDrawerSummary);
        }
      });
    }
  });
</script>
