<script>
  document.addEventListener('DOMContentLoaded', () => {
    const ridgeline = document.querySelector('#usa-ridgeline');

    if (!ridgeline) {
        console.error('Element #usa-ridgeline not found');
        return;
    }


    const checkVisibility = () => {
        const boundingRect = ridgeline.getBoundingClientRect();
        if (boundingRect.top < window.innerHeight && boundingRect.bottom > 0) {
            ridgeline.classList.add('in-view');
        }
    };

    checkVisibility();


    document.addEventListener('scroll', checkVisibility);
});
  </script>

