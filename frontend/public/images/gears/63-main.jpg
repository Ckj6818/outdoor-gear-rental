<style>
  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  .header__heading-logo {
    max-width: 160px;
  }

  @media screen and (min-width: 990px) {
    header-drawer {
      display: none;
    }
  }

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }

  /* Accordion styles for grandchild menu */
  .menu-drawer__accordion {
    position: relative;
  }

  .menu-drawer__accordion-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
  }

  .menu-drawer__accordion-summary::-webkit-details-marker {
    display: none;
  }

  .menu-drawer__accordion-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .menu-drawer__accordion-icon .icon-plus {
    display: block;
    width: 16px;
    height: 16px;
  }

  .menu-drawer__accordion-icon .icon-minus {
    display: none;
    width: 16px;
    height: 16px;
  }

  .menu-drawer__accordion[open] .menu-drawer__accordion-icon .icon-plus {
    display: none;
  }

  .menu-drawer__accordion[open] .menu-drawer__accordion-icon .icon-minus {
    display: block;
  }

  .menu-drawer__accordion-content {
    padding-left: 1.5rem;
    margin-top: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out, opacity 0.3s ease-out;
  }

  .menu-drawer__accordion:not([open]) .menu-drawer__accordion-content {
    max-height: 0;
    opacity: 0;
  }

  .menu-drawer__accordion[open] .menu-drawer__accordion-content {
    max-height: 1000px;
    opacity: 1;
  }

  .menu-drawer__accordion-content .menu-drawer__menu-item {
    padding-left: 1rem;
  }

  /* Prevent accordion from being treated as sliding submenu */
  .menu-drawer__accordion .menu-drawer__accordion-content {
    position: static;
    transform: none;
    visibility: visible;
    border-left: none;
    background-color: transparent;
  }

  /* Make menu drawer full height */
  .menu-drawer {
    top: -40px !important;
    height: 100vh !important;
    height: 100dvh !important;
  }

  .js menu-drawer > details > summary::before {
    height: 100vh !important;
    height: 100dvh !important;
    top: 0 !important;
  }

  .menu-drawer__inner-container {
    height: 100% !important;
  }

  .menu-drawer__navigation-container {
    height: 100% !important;
    display: flex !important;
    flex-direction: column !important;
  }

  .menu-drawer__navigation {
    flex: 1;
    overflow-y: auto;
  }

  .menu-drawer__utility-links {
    flex-shrink: 0;
    margin-top: auto;
  }
</style><style data-shopify>.header {
    padding-top: 4px;
    padding-bottom: 4px;
  }

  .section-header {
    margin-bottom: 0px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: 0px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: 8px;
      padding-bottom: 8px;
    }
  }
  @media screen and (max-width:990px){
    .header__icon--cart{
      margin-right:0px !important;
    }
  }
  .menu-drawer__utility-links {
    display: flex; 
    align-items: center;
    justify-content: space-between;
  }
  .menu-drawer__header {
    padding: 20px 18px 0;
  }
  .menu-drawer__header-icon {
    width: 26px;
    height: auto;
    margin-top: 20px;
  }
  .menu-drawer__header-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .menu-drawer__header-close {
    display: flex;
    justify-content: flex-end;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    align-items: center;
    margin-left: auto;
  }
  .menu-drawer__header-close svg {
    width: 16px;
    height: 16px;
    color: white;
