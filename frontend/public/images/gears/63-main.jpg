    <script>
      // JavaScript backup for dynamically loaded content
      function forceHideOnMobile() {
          if (window.innerWidth <= 768) {
              const launcher = document.getElementById('launcher');
              if (launcher) {
                  launcher.style.setProperty('display', 'none', 'important');
                  launcher.style.setProperty('visibility', 'hidden', 'important');
                  launcher.style.setProperty('opacity', '0', 'important');
              }
          }
      }

      // Multiple triggers to ensure it works
      document.addEventListener('DOMContentLoaded', forceHideOnMobile);
      window.addEventListener('load', forceHideOnMobile);
      window.addEventListener('resize', forceHideOnMobile);

      // For dynamically injected content
      const observer = new MutationObserver(forceHideOnMobile);
      observer.observe(document.body, { childList: true, subtree: true });
    </script>

