  /* Base styles for the navigation bar */
  .navbar {
    display: flex;
    background-color: #2b6b2b; /* Adjust color as needed */
    padding: 10px;
  }

  .new-bar {
    position: relative;
    margin-right: 20px;
    display: flex;
    align-items: center;
  }

  .new-bar a {
    font-size: 16px;
    text-decoration: none;
    color: white;
    padding: 10px 15px;
    background-color: #2b6b2b; /* Adjust color as needed */
  }

  .new-bar a:hover {
    background-color: #4a9c4a; /* Adjust hover color as needed */
  }

  /* Container needed to position the dropdown content */
  .dropdown {
    position: relative;
    display: inline-block;
  }

  /* Dropdown content (hidden by default) */
  .dropdown-content {
    display: none;
    position: absolute;
    background-color: #2b6b2b; /* Adjust color as needed */
    min-width: 160px;
    box-shadow: 0px 8px 16px 0px rgba(0, 0, 0, 0.2);
    z-index: 1;
    top: 100%;
    left: 0;
  }

  /* Links inside the dropdown */
  .dropdown-content a {
    color: white;
    padding: 12px 16px;
    text-decoration: none;
    display: block;
  }

  /* Change color of dropdown links on hover */
  .dropdown-content a:hover {
    background-color: #4a9c4a;
  }

  /* Show the dropdown menu on hover */
  .new-bar:hover .dropdown-content {
    display: block;
  }
  .section-header.shopify-section-group-header-group {
    margin-bottom: 0 !important;
  }

  .brand-selector-desktop {
    height: 59px;
    display: flex;
    align-items: center;
    border-bottom-width: 0px;
  }

  .utility-bar__inner-wrapper {
    height: 100%;
    display: flex;
    width: 100%;
  }

  .logo-item-cascade{
    border-right: 1px solid white;
  }
  .logo-item-cascade img {
    max-width:unset;
  }
  a.logo-item-cascade.logo-item  {
    margin: 0 0 0 5px;
    height: 70%;
  }

  .logo-item-msr {
    width: 5vw;
  }

  .logo-item-thermarest {
    width: 110px;
  }

  .logo-item-wrapper {
    display: flex;
