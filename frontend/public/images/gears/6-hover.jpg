<script>
  document.addEventListener('DOMContentLoaded', function () {
    var dialogId = 'localization_modal-87';
    var dialog = document.getElementById(dialogId);

    if (window.innerWidth < 750 && dialog && dialog.parentNode !== document.body) {
      dialog.classList.add('menu-drawer__localization', 'header-localization');
      document.body.appendChild(dialog);
    }

    try {
      var reopenDialogId = sessionStorage.getItem('reopenLocalizationDialogId');
      if (!reopenDialogId) return;

      var opener = document.querySelector('[data-a11y-dialog-show="' + reopenDialogId + '"]');
      if (opener) opener.click();

      sessionStorage.removeItem('reopenLocalizationDialogId');
    } catch (e) {
      // no-op
    }
  });
</script>

        
