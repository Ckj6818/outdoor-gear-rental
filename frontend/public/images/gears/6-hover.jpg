    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const currentLocale = window.location.pathname.match(/^\/([a-z]{2}-[a-z]{2})\//);
        if (currentLocale) {
          document.querySelectorAll('a[href^="/"]').forEach((link) => {
            // Skip if link already has locale
            if (
              !link.href.includes('/en-ca/') &&
              !link.href.includes('/en-us/') &&
              !link.href.includes('/fr-ca/') &&
              !link.href.includes('/fr-eu/') &&
              !link.href.includes('/en-eu/') &&
              !link.href.includes('/de-ca/') &&
              !link.href.includes('/de-eu/')
            ) {
              const href = link.getAttribute('href');
              // Only modify internal paths that start with /
              if (href && href.startsWith('/') && !href.startsWith('//')) {
                link.href = '/' + currentLocale[1] + href;
              }
            }
          });
        }
      });
    </script>
    
