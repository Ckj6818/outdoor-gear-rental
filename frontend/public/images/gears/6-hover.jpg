<style>
#localization_modal-917 {
  z-index: 2147483000 !important;
}

#localization_modal-917 .custom-dialog-overlay {
  z-index: 2147483001 !important;
}

#localization_modal-917 .custom-dialog-content.localization_modal-dialog {
  z-index: 2147483002 !important;
}

@media screen and (max-width: 749px) {
  #localization_modal-917 {
    position: fixed !important;
    inset: 0 !important;
  }

  #localization_modal-917 .custom-dialog-overlay {
    position: fixed !important;
    inset: 0 !important;
  }

  #localization_modal-917 .custom-dialog-content.localization_modal-dialog {
    position: fixed !important;
    top: 35% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;

    width: calc(100% - 32px) !important;
    max-width: 540px !important;
    min-height: 500px !important;
    max-height: 80vh !important;
    overflow-y: auto !important;
  }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var dialogId = 'localization_modal-917';
    var dialog = document.getElementById(dialogId);

    if (window.innerWidth < 750 && dialog && dialog.parentNode !== document.body) {
      dialog.classList.add('menu-drawer__localization', 'header-localization');
      document.body.appendChild(dialog);
    }

    try {
      var reopenDialogId = sessionStorage.getItem('reopenLocalizationDialogId');
      if (!reopenDialogId) return;

      var opener = document.querySelector('[data-a11y-dialog-show="' + reopenDialogId + '"]');
      if (opener) opener.click();

      sessionStorage.removeItem('reopenLocalizationDialogId');
    } catch (e) {
      // no-op
    }
  });
</script>

                
